[core]
  pager = delta
  editor = vim

[interactive]
  diffFilter = delta --color-only

[delta]
  navigate = true
  side-by-side = true
  line-numbers = true
  syntax-theme = TwoDark
  hyperlinks = true
  file-style = bold yellow ul
  file-decoration-style = yellow ol
  hunk-header-style = file line-number syntax
  hunk-header-decoration-style = blue box bold
  line-numbers-left-style = blue
  line-numbers-right-style = blue
  line-numbers-minus-style = red bold
  line-numbers-plus-style = green bold
  minus-style = syntax "#3a1d2e"
  minus-emph-style = syntax "#6b2040"
  plus-style = syntax "#1a3a2a"
  plus-emph-style = syntax "#2a6040"
  blame-palette = "#1e1e2e" "#181825" "#11111b" "#313244"

[merge]
  conflictstyle = diff3

[diff]
  colorMoved = default

[alias]
  unstage = reset HEAD --
  undo = reset --soft HEAD~1
  amend = commit --amend --no-edit

[init]
  defaultBranch = main

[pull]
  rebase = true

[push]
  autoSetupRemote = true

[rerere]
  enabled = true
